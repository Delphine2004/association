# Base de donnéees - Mysql
MYSQL_VERSION=8.0.32
MYSQL_CHARSET=utf8mb4
MYSQL_DATABASE=association_db
MYSQL_USER=association
MYSQL_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_me

## Base de données - MongoDB
MONGO_HOST=mongo
