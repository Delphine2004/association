{% extends 'base.html.twig' %} {% block title %}Espace utilisateur -
Informations compte{% endblock %} {% block body %}

<main class="pt-5">
    <section id="admin-account" class="py-5">
        <div class="container">
            <h1 class="text-center mb-4">Information du compte</h1>

            <div class="mx-auto" style="max-width: 700px">
                <!-- Card utilisateur -->
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body">
                        <!-- Ligne : Id -->
                        <div
                            class="d-flex justify-content-between py-2 border-bottom"
                        >
                            <strong>Id</strong>
                            <span>{{ user.id }}</span>
                        </div>

                        <!-- Ligne : Email -->
                        <div
                            class="d-flex justify-content-between py-2 border-bottom"
                        >
                            <strong>Email</strong>
                            <span>{{ user.email }}</span>
                        </div>

                        <!-- Ligne : Rôle -->
                        <div
                            class="d-flex justify-content-between py-2 border-bottom"
                        >
                            <strong>Rôle</strong>
                            <span>{{ user.role.name }}</span>
                        </div>

                        <!-- Ligne : Date de création -->
                        <div
                            class="d-flex justify-content-between py-2 border-bottom"
                        >
                            <strong>Date de création</strong>
                            <span>
                                {{ user.createdAt ? user.createdAt|date('Y-m-d H:i') : '' }}
                            </span>
                        </div>

                        <!-- Ligne : Dernière modification -->
                        <div class="d-flex justify-content-between py-2">
                            <strong>Dernière modification</strong>
                            <span>
                                {{ user.updatedAt ? user.updatedAt|date('Y-m-d H:i') : '' }}
                            </span>
                        </div>
                    </div>
                </div>

                <!-- Actions -->
                <div
                    class="d-flex flex-column flex-sm-row gap-3 justify-content-center mb-4"
                >
                    <a
                        class="btn flex-fill"
                        href="{{ path('app_admin_edit', { id: user.id }) }}"
                    >
                        Modifier
                    </a>
                </div>
            </div>
        </div>
    </section>
</main>

{% endblock %}
