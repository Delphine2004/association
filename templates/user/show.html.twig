{% extends 'base.html.twig' %} {% block title %}Espace utilisateur - Information
compte{% endblock %} {% block body %}

<main class="pt-5">
    <section id="adoption" class="container-fluid py-5">
        <div class="container mx-auto">
            <h1 class="text-center mb-4">Information du compte</h1>
        </div>

        <div class="row justify-content-center">
            <div class="col-12 col-md-10 col-lg-8">
                <table class="table">
                    <tbody>
                        <tr>
                            <th>Id</th>
                            <td>{{ user.id }}</td>
                        </tr>
                        <tr>
                            <th>Email</th>
                            <td>{{ user.email }}</td>
                        </tr>
                        <tr>
                            <th>Rôle</th>
                            <td>{{ user.role.name }}</td>
                        </tr>
                        <tr>
                            <th>Date de Création</th>
                            <td>
                                {{ user.createdAt ? user.createdAt|date('Y-m-d H:i:s') : '' }}
                            </td>
                        </tr>
                        <tr>
                            <th>Date de modification</th>
                            <td>
                                {{ user.updatedAt ? user.updatedAt|date('Y-m-d H:i:s') : '' }}
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="row justify-content-center mt-4">
            <div class="col-auto">
                <a
                    class="btn"
                    href="{{ path('app_user_edit', { id: user.id }) }}"
                    >Modifier</a
                >
            </div>
        </div>
        <div class="row justify-content-center mt-4">
            <div class="col-auto">
                <a class="btn" href="{{ path('user_dashboard') }}"
                    >Revenir sur le tableau de bord</a
                >
            </div>
        </div>
    </section>
</main>

{% endblock %}
