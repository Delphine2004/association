{% extends 'base.html.twig' %} {% block title %}User{% endblock %} {% block body
%}
<main class="pt-5">
    <section id="adoption" class="container-fluid py-5">
        <div class="container mx-auto">
            <h1 class="text-center mb-4">Utilisateur</h1>
            <div class="row justify-content-center">
                <table class="table">
                    <tbody>
                        <tr>
                            <th>Id</th>
                            <td>{{ user.id }}</td>
                        </tr>
                        <tr>
                            <th>Email</th>
                            <td>{{ user.email }}</td>
                        </tr>
                        <tr>
                            <th>Rôle</th>
                            <td>{{ user.role.name }}</td>
                        </tr>
                        <tr>
                            <th>Création</th>
                            <td>
                                {{ user.createdAt ? user.createdAt|date('Y-m-d H:i:s') : '' }}
                            </td>
                        </tr>
                        <tr>
                            <th>Modification</th>
                            <td>
                                {{ user.updatedAt ? user.updatedAt|date('Y-m-d H:i:s') : '' }}
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="row justify-content-center mt-4">
                <div class="col-auto">
                    <a
                        class="btn"
                        href="{{ path('app_user_edit', { id: user.id }) }}"
                        >Modifier</a
                    >
                </div>
                <div class="col-auto">
                    <a class="btn" href="{{ path('app_user_index') }}"
                        >Revenir à la liste</a
                    >
                </div>
            </div>
        </div>
    </section>
</main>
{{ include("user/_delete_form.html.twig") }}
{% endblock %}
