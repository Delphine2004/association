{% extends 'base.html.twig' %}
{% block title %}Espace utilisateur
{% endblock %}
{% block body %}
	<main class="pt-5">
		<section class="container-fluid py-5">
			<div class="container">
				<h1 class="text-center m-3">Tableau de bord</h1>
			</div>
		</section>
		<section class="container-fluid py-5">
			<div class="container">
				<div class="row justify-content-center">
					<div class="col-12 col-md-10 col-lg-8">
						<div class="card shadow-sm">
							<div class="card-header bg-light-pink text-brown">
								<h2 class="text-center m-3">Animaux à examiner</h2>
							</div>

							<div class="card-body p-0">
								<div class="row">
									{% if animals|length > 0 %}
										{% for animal in animals %}
											<div
												class="col-12">
												<!-- adapte selon le nombre de cartes par ligne -->
												<div class="card border-bottom p-3 w-100">
													<div class="card-body d-flex flex-column flex-md-row justify-content-between align-items-center gap-3 p-0">
														<p class="card-text mb-0 text-md-start text-center">{{ animal.name }}
															-
															{{ animal.type.value }}</p>
														<a class="btn btn-sm" href="{{ path('app_animal_edit', { id: animal.id }) }}">Voir</a>
													</div>
												</div>
											</div>
										{% endfor %}
									{% else %}
										<div class="col-12">
											<p class="text-center text-muted py-4">Aucun animal à examiner.</p>
										</div>
									{% endif %}
								</div>
							</div>


							<div class="card-footer bg-light-pink">
								<div class="d-flex flex-column flex-md-row justify-content-center m-3 gap-3">
									<a class="btn" href="{{ path('app_animal_page') }}">Animaux</a>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="container-fluid mb-5 py-5">
			<div class="container">
				<div class="row justify-content-center">
					<div class="col-12 col-md-10 col-lg-8">
						<div class="card shadow-sm">
							<div class="card-header bg-light-pink text-brown py-3">
								<h2 class="text-center m-3">Evénement à venir</h2>
							</div>

							<div class="card-body p-0">
								<div class="row">
									{% if events|length > 0 %}
										{% for event in events %}
											<div class="col-12">
												<div class="card border-bottom p-3 w-100">
													<div class="card-body d-flex flex-column flex-md-row justify-content-between align-items-center gap-3 p-0">
														<div class="d-flex gap-1">
															<p class="card-text  mb-0 text-md-start text-center">
																{{ event.date ? event.date|date('d/m/Y') : '' }}
															</p>
															<p class="card-text  mb-0 text-md-start text-center">{{ event.place }}</p>
														</div>
														<a class="btn btn-sm btn-primary" href="{{ path('app_event_edit', { id: event.id }) }}">
															Voir
														</a>
													</div>
												</div>
											</div>
										{% endfor %}
									{% else %}
										<div class="col-12">
											<p class="text-center text-muted py-4">Aucun événement à venir.</p>
										</div>
									{% endif %}
								</div>
							</div>


							<div class="card-footer bg-light-pink">
								<div class="d-flex flex-column flex-md-row justify-content-center m-3 gap-3">
									<a class="btn" href="{{ path('app_event_page') }}">Evénements</a>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>
	</main>
{% endblock %}
