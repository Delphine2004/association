{# Messages succès #} {% for message in app.flashes('success') %}
<div
    class="alert alert-success alert-dismissible fade show p-2 mb-2"
    role="alert"
    style="font-size: 0.9rem"
>
    {{ message }}
    <button
        type="button"
        class="btn-close btn-sm"
        data-bs-dismiss="alert"
        aria-label="Close"
    ></button>
</div>
{% endfor %} {# Messages erreur #} {% for message in app.flashes('error') %}
<div
    class="alert alert-danger alert-dismissible fade show p-2 mb-2"
    role="alert"
    style="font-size: 0.9rem"
>
    {{ message }}
    <button
        type="button"
        class="btn-close btn-sm"
        data-bs-dismiss="alert"
        aria-label="Close"
    ></button>
</div>
{% endfor %}
