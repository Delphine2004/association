{% extends 'base.html.twig' %}
{% block title %}Espace Admin
{% endblock %}
{%
block body %}

	<main class="pt-5">
		<section class="container-fluid py-5">
			<div class="container">
				<div class="row justify-content-center align-items-center">
					<div class="col-12 col-md-10 col-lg-8">
						<div class="card shadow-sm">
							<div class="card-header bg-light-pink py-3">
								<h2 class="text-center m-3">
									Gestion des utilisateurs
								</h2>
							</div>

							<div class="card-body p-0">
								<div class="row">
									{% if users|length > 0 %}
										{% for user in users %}
											<div class="col-12">
												<div class="card border-bottom p-3 w-100">
													<div class="card-body d-flex flex-column flex-md-row justify-content-between align-items-center gap-3 p-0">
														<div class="d-flex flex-column flex-row-md gap-1">
															<p class="card-text mb-0 text-md-start text-center">{{ user.email }}</p>
															<p class="card-text mb-0 text-md-start text-center">
																{% set rolesList = [] %}
																{% for role in user.roles %}
																	{% if role != 'ROLE_USER' %}
																		{% set rolesList = rolesList|merge([role|replace({'ROLE_': ''})]) %}
																	{% endif %}
																{% endfor %}
																{{ rolesList|join(', ') }}
															</p>
														</div>
														<a class="btn btn-sm" href="{{ path('app_user_show', { id: user.id }) }}">Voir</a>
													</div>
												</div>
											{% endfor %}
										{% else %}
											<div class="col-12">
												<p class="text-center text-muted py-4">Aucun utilisateur trouvé.</p>
											</div>
										{% endif %}
									</div>
								</div>
							</div>

							<div class="card-footer bg-light-pink">
								<div class="d-flex flex-column flex-md-row justify-content-center m-3 gap-3">
									<a class="btn" href="{{ path('app_user_new') }}">Ajouter un utilisateur</a>
								</div>
							</div>
						</div>


					</div>
				</div>
			</section>
		</main>
	{% endblock %}
