{% extends 'base.html.twig' %} {% block title %}Espace Admin - Information
compte{% endblock %} {% block body %}

<main class="pt-5">
    <section
        id="admin-account"
        class="container-fluid py-5 d-flex justify-content-center align-items-center"
        style="min-height: 70vh"
    >
        <div class="container">
            <h1 class="text-center mb-4">Information du compte</h1>

            <div class="mx-auto" style="max-width: 700px">
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body">
                        <!-- Ligne : Id -->
                        <div
                            class="d-flex justify-content-between py-2 border-bottom"
                        >
                            <strong>Id</strong>
                            <span>{{ user.id }}</span>
                        </div>

                        <!-- Ligne : Email -->
                        <div
                            class="d-flex justify-content-between py-2 border-bottom"
                        >
                            <strong>Email</strong>
                            <span>{{ user.email }}</span>
                        </div>

                        <!-- Ligne : Rôle -->
                        <div
                            class="d-flex justify-content-between py-2 border-bottom"
                        >
                            <strong>Rôle</strong>
                            <span>
                                {% for role in user.roles %} {% if role !=
                                'ROLE_USER' %}
                                {{ role|replace({'ROLE_': ''}) }}
                                {% endif %} {% endfor %}</span
                            >
                        </div>

                        <!-- Ligne : Date de création -->
                        <div
                            class="d-flex justify-content-between py-2 border-bottom"
                        >
                            <strong>Date de création</strong>
                            <span>
                                {{ user.createdAt ? user.createdAt|date('d/m/Y H:i') : '' }}
                            </span>
                        </div>

                        <!-- Ligne : Dernière modification -->
                        <div class="d-flex justify-content-between py-2">
                            <strong>Dernière modification</strong>
                            <span>
                                {{ user.updatedAt ? user.updatedAt|date('d/m/Y H:i') : '' }}
                            </span>
                        </div>
                    </div>
                </div>

                <!-- Actions -->
                <div
                    class="d-flex flex-column flex-sm-row gap-5 justify-content-center mb-4"
                >
                    <a
                        class="btn"
                        href="{{ path('app_admin_edit', { id: user.id }) }}"
                    >
                        Modifier
                    </a>

                    {{ include("admin/_delete_form.html.twig") }}
                </div>

                <!-- Retour -->
                <div class="text-center">
                    <a class="btn" href="{{ path('admin_dashboard') }}">
                        Revenir sur le tableau de bord
                    </a>
                </div>
            </div>
        </div>
    </section>
</main>

{% endblock %}
