{% extends 'base.html.twig' %} {% block title %}Espace Admin - Emails
Newsletter{% endblock %} {% block body %}
<main class="pt-5">
    <section id="admin-account" class="container-fluid py-5">
        <div class="container">
            <h1 class="text-center mb-5">
                Liste des emails inscrits à la newsletter
            </h1>
            <div class="mx-auto">
                {% if emails is empty %}
                <p>Aucun email trouvé.</p>
                {% else %}
                <ul>
                    {% for email in emails %}
                    <li>{{ email }}</li>
                    {% endfor %}
                </ul>
                {% endif %}
            </div>

            <div class="text-center mt-5">
                <a class="btn" href="{{ path('admin_dashboard') }}"
                    >Revenir au tableau de bord</a
                >
            </div>
        </div>
    </section>
</main>

{% endblock %}
