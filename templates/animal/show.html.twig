{% extends 'base.html.twig' %}

{% block title %}Animal{% endblock %}

{% block body %}
    <h1>Animal</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ animal.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ animal.name }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ animal.description }}</td>
            </tr>
            <tr>
                <th>Type</th>
                <td>{{ animal.type }}</td>
            </tr>
            <tr>
                <th>Race</th>
                <td>{{ animal.race }}</td>
            </tr>
            <tr>
                <th>Gender</th>
                <td>{{ animal.gender }}</td>
            </tr>
            <tr>
                <th>Status</th>
                <td>{{ animal.status }}</td>
            </tr>
            <tr>
                <th>Vaccinated</th>
                <td>{{ animal.vaccinated ? 'Yes' : 'No' }}</td>
            </tr>
            <tr>
                <th>Sterilized</th>
                <td>{{ animal.sterilized ? 'Yes' : 'No' }}</td>
            </tr>
            <tr>
                <th>Chipped</th>
                <td>{{ animal.chipped ? 'Yes' : 'No' }}</td>
            </tr>
            <tr>
                <th>CompatibleKid</th>
                <td>{{ animal.compatibleKid ? 'Yes' : 'No' }}</td>
            </tr>
            <tr>
                <th>CompatibleCat</th>
                <td>{{ animal.compatibleCat ? 'Yes' : 'No' }}</td>
            </tr>
            <tr>
                <th>CompatibleDog</th>
                <td>{{ animal.compatibleDog ? 'Yes' : 'No' }}</td>
            </tr>
            <tr>
                <th>Birthday</th>
                <td>{{ animal.birthday ? animal.birthday|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>ArrivalDate</th>
                <td>{{ animal.arrivalDate ? animal.arrivalDate|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ animal.createdAt ? animal.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>UpdatedAt</th>
                <td>{{ animal.updatedAt ? animal.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_animal_index') }}">back to list</a>

    <a href="{{ path('app_animal_edit', {'id': animal.id}) }}">edit</a>

    {{ include('animal/_delete_form.html.twig') }}
{% endblock %}
