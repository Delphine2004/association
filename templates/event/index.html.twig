{% extends 'base.html.twig' %} {% block title %}Espace utilisateur -
Evénements{% endblock %} {% block body %}

<main class="pt-5">
    <section id="event-page" class="container-fluid py-5">
        <div class="container">
            <h1 class="text-center mb-5">Gestion des événements</h1>

            <div class="text-center mb-5">
                <a class="btn btn-large" href="{{ path('app_event_new') }}"
                    >Ajouter un événement</a
                >
            </div>

            <div class="row justify-content-center">
                <div class="col-12 col-md-10 col-lg-8">
                    <!-- Filtre -->
                    <div class="filter card shadow-sm border-0 p-4 mb-5">
                        <h5 class="text-center mb-4">
                            Rechercher un événement
                        </h5>

                        {{ form_start(searchForm, { method: "get" }) }}
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                {{ form_row(searchForm.id) }}
                            </div>
                            <div class="col-md-6">
                                {{ form_row(searchForm.date) }}
                            </div>
                        </div>

                        <div class="text-center">
                            <button class="btn w-100">Rechercher</button>
                        </div>

                        {{ form_end(searchForm) }}
                    </div>

                    <!-- Résultats -->
                    <div class="table-responsive shadow-sm border rounded">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th scope="col">Id</th>
                                    <th scope="col">Date</th>
                                    <th scope="col">Lieu</th>
                                    <th scope="col" class="text-center">
                                        Actions
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for event in events %}
                                <tr>
                                    <td>{{ event.id }}</td>
                                    <td>
                                        {{ event.date|date('d/m/Y') }}
                                    </td>
                                    <td>{{ event.place }}</td>
                                    <td class="text-center">
                                        <a
                                            class="btn btn-sm"
                                            href="{{
                                                path('app_event_show', {
                                                    id: event.id
                                                })
                                            }}"
                                            >Voir</a
                                        >
                                    </td>
                                </tr>
                                {% else %}
                                <tr>
                                    <td
                                        colspan="4"
                                        class="text-center text-muted py-4"
                                    >
                                        Aucun événement
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>
{% endblock %}
