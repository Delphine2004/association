{% extends 'base.html.twig' %} {% block title %}Evénement - Modification{%
endblock %} {% block body %}

<main class="pt-5">
    <section id="event-page" class="container-fluid py-5">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-12 col-md-10 col-lg-8">
                    <h1 class="text-center m-5">Modification de l'événement</h1>

                    <div
                        class="card bg-light-pink shadow-sm d-flex justify-content-evenly p-4"
                    >
                        {{
                            include("event/_form.html.twig", {
                                button_label: "Modifier"
                            })
                        }}
                    </div>

                    <div class="m-5">
                        {% include 'partials/_flash.html.twig' %}
                    </div>
                </div>
            </div>

            <div class="text-center m-5">
                <a
                    class="btn"
                    href="{{
                        path('app_event_show', {
                            id: event.id
                        })
                    }}"
                    >Revenir à l'événement</a
                >
            </div>
        </div>
    </section>
</main>
{% endblock %}
