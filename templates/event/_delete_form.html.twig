<form
    method="post"
    action="{{ path('app_event_delete', { id: event.id }) }}"
    onsubmit="return confirm('Souhaitez vous confirmer la suppression?');"
>
    <input
        type="hidden"
        name="_token"
        value="{{ csrf_token('delete' ~ event.id) }}"
    />
    <button class="btn">Supprimer</button>
</form>
