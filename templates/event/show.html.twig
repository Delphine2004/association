{% extends 'base.html.twig' %} {% block title %}Evénement - Informations{%
endblock %} {% block body %}

<main class="pt-5">
    <section
        id="event-page"
        class="container-fluid py-5 d-flex justify-content-center align-items-center"
        style="min-height: 70vh"
    >
        <div class="container">
            <h1 class="text-center mb-4">Informations événement</h1>

            <div class="mx-auto" style="max-width: 700px">
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header">
                        <h2 class="text-center mb-4">Ref : {{ event.id }}</h2>
                    </div>
                    <div class="card-body">
                        <!--  -->
                        <div class="py-2 mb-3 border-bottom">
                            <div class="d-flex justify-content-between py-2">
                                <strong>Date</strong>
                                <span
                                    >{{ event.date ? event.date|date('d/m/Y') : '' }}</span
                                >
                            </div>

                            <div class="d-flex justify-content-between py-2">
                                <strong>Lieu</strong>
                                <span>{{ event.place }}</span>
                            </div>
                        </div>

                        <!--  -->
                        <div
                            class="d-flex justify-content-between py-2 border-bottom"
                        >
                            <strong>Description</strong>
                            <p>{{ event.description }}</p>
                        </div>

                        <!--  -->
                        <div>
                            <div class="d-flex justify-content-between py-2">
                                <strong>Création : </strong>
                                <span
                                    >{{ event.createdAt ? event.createdAt|date('d/m/Y H:i:s') : '' }}
                                    - {{ event.createdBy.email }}</span
                                >
                            </div>

                            <div
                                class="d-flex justify-content-between py-2 border-bottom"
                            >
                                <strong>Modification : </strong>
                                <span
                                    >{{ event.updatedAt ? event.updatedAt|date('d/m/Y H:i:s') : '' }}
                                    -
                                    {{
                                        event.updatedBy
                                            ? event.updatedBy.email
                                            : ""
                                    }}</span
                                >
                            </div>
                        </div>
                    </div>
                </div>
                {% if event.date >= "now"|date("Y-m-d") %}
                <div
                    class="d-flex flex-column flex-sm-row gap-5 justify-content-center mb-4"
                >
                    <a
                        class="btn"
                        href="{{ path('app_event_edit', { id: event.id }) }}"
                        >Modifier</a
                    >

                    {{ include("event/_delete_form.html.twig") }}
                </div>
                {% endif %}
            </div>

            <div class="mx-auto">
                <div
                    class="d-flex flex-column flex-sm-row justify-content-center mb-4"
                >
                    <a class="btn" href="{{ path('app_event_index') }}"
                        >Revenir aux événements</a
                    >
                </div>
            </div>
        </div>
    </section>
</main>

{% endblock %}
