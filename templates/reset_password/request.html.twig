{% extends 'base.html.twig' %}

{% block title %}Réinitialisation du mot de passe
{% endblock %}

{% block body %}
	<main class="pt-5">
		<section id="login" class="container-fluid py-5">
			<div class="container">
				<div class="row justify-content-center">
					<div class="col-12 col-md-10 col-lg-8">
						{% for flash_error in app.flashes('reset_password_error') %}
							<div class="alert alert-danger" role="alert">{{ flash_error }}</div>
						{% endfor %}
						<h1 class="text-center m-3">Réinitialisation du mot de passe</h1>

						<div class="card bg-light-pink shadow-sm d-flex justify-content-evenly p-4">
							<div class="text-center m-3">
								<p>
									Entrez votre adresse email pour recevoir un lien de réinitialisation.
								</p>
							</div>

							{{ form_start(requestForm) }}
							{{ form_row(requestForm.email) }}

							<div class="text-center m-3">
								<button class="btn">Recevoir l'email</button>
							</div>
							{{ form_end(requestForm) }}
						</div>
					</div>
				</div>
			</div>
		</section>
	</main>
{% endblock %}
