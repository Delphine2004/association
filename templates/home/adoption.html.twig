{% extends 'base.html.twig' %} {% block title %}Adoption - Coeurs à Quatre
Pattes{% endblock %} {% block body %}
<section id="adoption" class="container-fluid">
    <div class="row mb-4 justify-content-center">
        <div class="col-12 mx-auto text-center">
            <div class="col-12">
                <img
                    src="{{ asset('assets/img/autres/hero-adoption.jpg') }}"
                    alt="Chien et chat qui se câlinent"
                    class="img-fluid rounded"
                    style="max-width: 70%; height: auto"
                />
            </div>
        </div>

        <div class="row justify-content-center align-items-center mt-4">
            <div class="m-auto">
                <h1 class="text-center mb-3">Adopter un animal</h1>
            </div>
            <div class="col-12 col-md-6">
                <p class="lead">
                    Offrez une seconde chance à un compagnon qui n'attend que
                    vous. Nos animaux sont vaccinés, stérilisés et prêts à
                    rejoindre leur foyer pour toujours. Chiens, chats, lapins...
                    chacun mérite une famille aimante. Parcourez nos profils et
                    trouvez celui qui fera battre votre cœur.
                </p>
            </div>
            <div
                class="col-12 col-md-4 d-flex justify-content-md-start justify-content-end"
            >
                <a href="#" class="btn align-self-center"
                    >Conditions d'adoption</a
                >
            </div>
        </div>
    </div>
</section>

<section class="adoption-search container-fluid">
    <div>
        <form id="filter-bar">
            <div class="mb-3">
                <label for="disabledSelect" class="form-label"
                    >Disabled select menu</label
                >
                <select id="disabledSelect" class="form-select">
                    <option>Disabled select</option>
                </select>
            </div>
            <div class="mb-3">
                <label for="disabledSelect" class="form-label"
                    >Disabled select menu</label
                >
                <select id="disabledSelect" class="form-select">
                    <option>Disabled select</option>
                </select>
            </div>
            <div class="mb-3">
                <label for="disabledSelect" class="form-label"
                    >Disabled select menu</label
                >
                <select id="disabledSelect" class="form-select">
                    <option>Disabled select</option>
                </select>
            </div>
            <button type="submit" class="btn btn-primary">Rechercher</button>
        </form>
    </div>
</section>
{% endblock %}
